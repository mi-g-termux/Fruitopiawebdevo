rules_version = '2';

// Fruitopia – Firestore security rules
//
// Goal:
//  - Storefront (anonymous visitors) can READ products, categories, coupons,
//    reviews and adminSettings (for live login validation).
//  - Anyone can SUBSCRIBE to newsletter and CREATE an order.
//  - Only signed-in admins (Firebase Auth) can WRITE catalog data,
//    update coupons / orders, or change admin credentials.
//
// This is what fixes "Missing or insufficient permissions" when a customer
// types a coupon code on the public site — the storefront has no auth token,
// so without these public-read rules every getDocs() call fails.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ---- Public catalog (read by everyone, write by admin only) ----
    match /products/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /categories/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /coupons/{id} {
      // public READ so the storefront can validate codes
      allow read: if true;
      // only admins can create / edit / delete coupons
      allow write: if isSignedIn();
    }
    match /reviews/{id} {
      allow read: if true;
      // customers can submit reviews
      allow create: if true;
      allow update, delete: if isSignedIn();
    }

    // ---- Admin credentials ----
    // Public READ is required because the admin login form validates the
    // typed username/password against this doc BEFORE signing into Firebase
    // Auth. Document only contains a username + password hash you set
    // yourself, no PII.
    match /adminSettings/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ---- Orders ----
    match /orders/{id} {
      // customers can place an order without an account
      allow create: if true;
      // only admins can list / read / modify orders
      allow read, update, delete: if isSignedIn();
    }

    // ---- Newsletter ----
    match /newsletter/{id} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }

    // ---- Users (admin accounts) ----
    match /users/{id} {
      allow read, write: if isSignedIn();
    }

    // Deny anything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
